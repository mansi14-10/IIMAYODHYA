      <a class="no-underline" data-tracking-control-name="inline-recommended-articles" data-tracking-will-navigate href="https://www.linkedin.com/pulse/wine-packaging-1800s-coca-cola-2020-bordeaux-futures-greg">
          <img class="content-image w-full h-[150px] bg-cover rounded-t-md object-cover" data-delayed-url="https://media.licdn.com/dms/image/v2/C5612AQEsKebtZXWqBA/article-cover_image-shrink_600_2000/article-cover_image-shrink_600_2000/0/1621598933803?e=2147483647&amp;v=beta&amp;t=smnuVh0qwMaqnyf0Qo-eyHfiLxvHh3Jej4OFo2NtYSs">
                  
             <div class="inline-article-title text-md text-color-text font-bold pl-2 pt-1 pr-1.5">Wine Packaging: 1800s Coca-Cola to 2020 Bordeaux…</div>
            

          
              <div class="inline-article-meta px-2 mt-1 font-sans text-xs font-normal text-color-text-low-emphasis h-full">
                   <span class="inline-article-author pt-0.5">
                    Greg Martellotto, MPH
                   </span>
    
                                <span class="before:middot pt-0.5 inline-article-published-date">
                  

    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    

    
    
    
    
    
    
    
    
    
    
    
    
    
    

