      <img class="inline-block relative
          
          w-6 h-6
          " data-delayed-url="https://media.licdn.com/dms/image/v2/C560BAQHZnQf3t8fKKg/company-logo_100_100/company-logo_100_100/0/1630670609155/ford_motor_company_logo?e=2147483647&amp;v=beta&amp;t=RJaj5pQAZB9Jvw_djO71CdhBJVBlOH7NLolHoWLOxJQ" data-ghost-classes="bg-color-entity-ghost-background" data-ghost-url="https://static.licdn.com/aero-v1/sc/h/cs8pjfgyw96g44ln9r7tct85f" alt="Ford Motor Company">
  

        <div class="base-main-card__info self-center ml-1 flex-1 relative break-words papabear:min-w-0 mamabear:min-w-0 babybear:w-full">
<!---->          <h3 class="base-main-card__title font-sans text-[18px] font-bold text-color-text overflow-hidden
              ">
            
        Ford Motor Company
      
          </h3>
          

<!---->
<!---->
              <div class="body-text text-color-text-low-emphasis base-main-card__metadata">
                
          Published Jun 13, 2023
      
              </div>
<!---->        </div>

          <div class="base-main-card__ctas z-[3] self-center ml-3 babybear:ml-1 babybear:self-start">
            
          <a class="base-main-card__cta btn-sm btn-secondary" href="https://www.linkedin.com/signup/cold-join?session_redirect=%2Fpulse%2Fford-unveils-120th-anniversary-themed-menu-based-1930s-era&amp;trk=article-ssr-frontend-pulse_publisher-author-card" data-tracking-control-name="article-ssr-frontend-pulse_publisher-author-card" data-tracking-will-navigate>
